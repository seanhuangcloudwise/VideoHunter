# B站登录凭证（可选，部分字幕接口需要）
# 获取方式：浏览器登录 bilibili.com → F12 → Application → Cookies → 复制 SESSDATA
BILIBILI_SESSDATA=

# Whisper 模型大小（base / small / medium），默认 base（CPU 友好）
WHISPER_MODEL=base

# 默认搜索结果数量
SEARCH_LIMIT=5

# 是否在输出 Markdown 中保留完整字幕/转写文本（true/false）
KEEP_FULL_TEXT=true

# 是否自动为“中心思想”中的关联发言补全时间范围（true/false）
AUTO_ADD_IDEA_TIME=true
